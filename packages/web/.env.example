# Apis web app — required + optional environment variables.
#
# Copy to `.env.local` for local dev (gitignored). Configure in the
# Vercel dashboard for production.

# ─── Required (production) ──────────────────────────────────────────────

# Pinata JWT (Files: Write scope). Used as both the IPFS pinner for
# results AND the key-value store for the buyer↔worker side-channels
# (see app/lib/pinata-store.ts). Same JWT the worker already uses.
# Sign up at https://app.pinata.cloud/, create an API key with
# "Files: Write" scope, paste the JWT here.
PINATA_JWT=

# Deployer keypair, JSON array (matches the format of
# ~/.config/solana/id.json). Used by /api/faucet to mint test USDC to
# whichever wallet asks for a drip. The deployer is also the mint
# authority for the test SPL mint configured in app/lib/constants.ts.
#
# Devnet test mint has no real-money value, so storing the keypair here
# is acceptable for the hackathon submission. Rotate before mainnet.
# Without this, /api/faucet returns 503 and /submit silently hides the
# "Get 10 USDC" button.
#
# To populate: copy the contents of ~/.config/solana/id.json verbatim
# into Vercel's env-var value field (it's a 64-element JSON array).
APIS_DEPLOYER_KEYPAIR=

# ─── Optional ──────────────────────────────────────────────────────────

# Override the Solana RPC URL the API routes use (defaults to public
# devnet). Use Helius / Triton on prod for higher rate limits.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Override the local fallback for the spec FS channel (when KV creds
# unset). Worker reads from APIS_SPEC_DIR.
# APIS_SPEC_DIR=/tmp/apis_specs

# Override the local fallback for the result FS channel.
# APIS_RESULT_DIR=/tmp/apis_results

# Override the FS-mode KV root (filesystem fallback when PINATA_JWT
# unset). Each entry stored at `{APIS_FS_KV_DIR}/{namespace}/{key}.json`.
# APIS_FS_KV_DIR=/tmp/apis_kv
